# ==============================================================
# TrueID Configuration
# Copy: cp .env.example .env
# Generate secrets: make secrets
# ==============================================================

# -- Required Secrets (generate with: make secrets) --
JWT_SECRET=
ENGINE_SERVICE_TOKEN=
CONFIG_ENCRYPTION_KEY=

# -- Recommended --
ARGON2_PEPPER=

# -- Initial Admin (first run only) --
TRUEID_ADMIN_USER=admin
TRUEID_ADMIN_PASS=

# -- Database --
DATABASE_URL=sqlite:///app/data/net-identity.db?mode=rwc

# -- Network Listeners --
RADIUS_BIND=0.0.0.0:1813
RADIUS_SECRET=secret
AD_SYSLOG_BIND=0.0.0.0:5514
DHCP_SYSLOG_BIND=0.0.0.0:5516
VPN_SYSLOG_BIND=0.0.0.0:5518

# -- Engine/Web internals --
ADMIN_HTTP_BIND=0.0.0.0:8080
ENGINE_API_URL=http://engine:8080
ASSETS_DIR=/app/assets

# -- Web Dashboard --
WEB_PORT=3000
HTTP_BIND=0.0.0.0:3000

# -- TLS (optional, for agent mTLS) --
# TLS_CA_CERT=/app/tls/ca.pem
# TLS_SERVER_CERT=/app/tls/server.pem
# TLS_SERVER_KEY=/app/tls/server-key.pem
# TLS_CERT_DIR=./tls

# -- Web HTTPS (optional) --
# WEB_TLS_CERT=/app/tls/web.pem
# WEB_TLS_KEY=/app/tls/web-key.pem

# -- OUI Vendor Database (optional) --
# OUI_CSV_PATH=./oui.csv

# -- GeoIP Database (optional) --
# GEOIP_DB_PATH=/app/data/GeoLite2-City.mmdb

# -- Docker Port Overrides --
# RADIUS_PORT=1813
# AD_SYSLOG_PORT=5514
# DHCP_SYSLOG_PORT=5516
# VPN_SYSLOG_PORT=5518

# -- Logging --
RUST_LOG=info

# -- Development --
TRUEID_DEV_MODE=false
