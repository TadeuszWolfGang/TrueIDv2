# TrueID — environment configuration
# Copy this file: cp .env.example .env
# Defaults work out of the box — change only if you know what you're doing.

# SQLite database (relative path, auto-created)
DATABASE_URL=sqlite://net-identity.db?mode=rwc

# Listener ports
RADIUS_BIND=0.0.0.0:1813
AD_SYSLOG_BIND=0.0.0.0:5514
DHCP_SYSLOG_BIND=0.0.0.0:5516

# Web dashboard
HTTP_BIND=0.0.0.0:3000

# Logging level (trace / debug / info / warn / error)
RUST_LOG=info
